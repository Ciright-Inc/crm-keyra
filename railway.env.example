# Copy these into Railway → crm-keyra service → Variables
# DATABASE_URL is set automatically when you link a PostgreSQL plugin.

# --- Required (link Postgres plugin; Railway sets DATABASE_URL) ---
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# PGSSLMODE=require

# --- Auth (production — shared Keyra session across all sites) ---
# Match translate-keyra / familyoffice-keyra: call auth.keyra.ie directly from the browser.
NEXT_PUBLIC_SIMSECURE_AUTH_BACKEND_URL=https://auth.keyra.ie
NEXT_PUBLIC_KEYRA_GET_STARTED_URL=https://get-started.keyra.ie
KEYRA_AUTH_BACKEND_URL=https://auth.keyra.ie
NEXT_PUBLIC_CRM_DEV_AUTH_BYPASS=false

# --- App ---
NODE_ENV=production

# --- Explicit login return (optional — baked into app for Railway host) ---
# NEXT_PUBLIC_CRM_LOGIN_RETURN_URL=https://crm-keyra-production.up.railway.app/login?auth_return=1

# --- Optional overrides ---
# NEXT_PUBLIC_CRM_LOGIN_POST_AUTH_PATH=/login?auth_return=1
# SKIP_DB_MIGRATE=false
