# Local / office network (default for dev on your LAN)
DATABASE_URL=postgresql://postgres:ciright@192.168.1.206:5432/keyra-auth

# Railway / cloud: must be the keyra-auth database (has auth_users tables), reachable from the host
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@your-host:5432/keyra-auth
# PGSSLMODE=require

# CRM now proxies auth through its own /api/keyra-auth route.
# Set either KEYRA_AUTH_BACKEND_URL or NEXT_PUBLIC_SIMSECURE_AUTH_BACKEND_URL to the upstream auth host.
# KEYRA_AUTH_BACKEND_URL=https://auth.keyra.ie
# NEXT_PUBLIC_SIMSECURE_AUTH_BACKEND_URL=https://auth.keyra.ie

NEXT_PUBLIC_CRM_DEV_AUTH_BYPASS=true
NEXT_PUBLIC_APP_NAME=crm.keyra.ie

# CRM uses database name keyra-auth — not an empty Railway Postgres unless you also migrate Keyra auth tables.
